<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background">

    <androidx.cardview.widget.CardView
        android:id="@+id/previewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardUseCompatPadding="true"
        app:cardBackgroundColor="@color/ios_card"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.camera.view.PreviewView
                android:id="@+id/viewFinder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:scaleType="fillStart" />

            <com.google.mediapipe.examples.poselandmarker.OverlayView
                android:id="@+id/overlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="false" />

            <TextView
                android:id="@+id/tvFps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="FPS 0.0"
                android:textColor="@color/gemini_yellow"
                android:textSize="12sp"
                android:gravity="center"
                android:alpha="0.9"
                android:layout_gravity="top|start" />

            <LinearLayout
                android:id="@+id/modeToggle"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_margin="12dp"
                android:layout_gravity="top|end"
                android:orientation="horizontal"
                android:background="@drawable/bg_toggle_mode"
                android:padding="2dp">

                <TextView
                    android:id="@+id/tabJump"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:text="Jump"
                    android:textSize="14sp"
                    android:textColor="@color/ios_text_primary"
                    android:background="@drawable/bg_toggle_mode_selected" />

                <TextView
                    android:id="@+id/tabSpin"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:text="Spin"
                    android:textSize="14sp"
                    android:textColor="@color/ios_text_secondary" />
            </LinearLayout>

            <FrameLayout
                android:id="@+id/btnRecord"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center_horizontal|bottom"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_record_outer"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:id="@+id/recordInner"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_record_circle" />
            </FrameLayout>
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:background="@color/ios_card"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/navRecord"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_camera" />

            <TextView
                android:id="@+id/navRecordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Record"
                android:textColor="@color/ios_text_primary"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navJumps"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_gallery" />

            <TextView
                android:id="@+id/navJumpsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumps"
                android:textColor="@color/ios_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
